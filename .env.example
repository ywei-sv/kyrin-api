# Kyrin API — Environment Variables (copy to .env and fill in)
KYRIN_API_KEY=sk-your-key-here
KYRIN_BASE_URL=https://opencode.ai/zen/go/v1
KYRIN_MODEL=deepseek-v4-flash
SEARXNG_URL=http://127.0.0.1:8080
TRACE_MOE_URL=https://api.trace.moe
PORT=5271

# Security (optional)
KYRIN_REQUIRE_API_KEY=0         # Set to 1 to require API key
KYRIN_RATE_LIMIT=               # e.g. 60/minute, 10/second; empty = disabled
